# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/supportai?sslmode=require

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# AI Gateway (VERCEL_OIDC_TOKEN is auto-provisioned on Vercel)
# For local dev, run: vercel env pull
# VERCEL_OIDC_TOKEN=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
TWILIO_WHATSAPP_NUMBER=whatsapp:+1...
# Optional: override webhook base URL (defaults to auto-detected host)
# TWILIO_WEBHOOK_BASE_URL=https://your-api.vercel.app

# Resend (transactional email)
RESEND_API_KEY=re_...
# Optional: override the default sender domain
# RESEND_DOMAIN=notifications.yourdomain.com

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
